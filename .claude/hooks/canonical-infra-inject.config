# canonical-infra-inject.config
# Pattern file for canonical infrastructure injection hook
# One regex pattern per line. Comments start with #.
#
# Patterns are matched against:
# - Bash tool: command string
# - Edit/Write/Read tools: file_path
#
# Cadence is controlled by CANONICAL_INJECTION_CADENCE env var (default: 10)

# ─────────────────────────────────────────────────────────────────────────────
# Command patterns (Bash tool)
# Note: No ^ anchor - allows env-prefixed forms like PGPASSWORD=... psql
# ─────────────────────────────────────────────────────────────────────────────

\bpsql\b
\bpg_dump\b
(^|/)aws(-cli)?\s
(^|/)kubectl\s
(^|/)terraform\s
(^|/)pulumi\s
\bssh\s
\brsync\s
\bdocker\s
\bdocker-compose\s

# ─────────────────────────────────────────────────────────────────────────────
# Path patterns (Edit/Write/Read tools)
# ─────────────────────────────────────────────────────────────────────────────

/infra/
/infrastructure/
/deploy/
/ops/
/terraform/
/k8s/
/kubernetes/

# ─────────────────────────────────────────────────────────────────────────────
# Hostname/URI patterns (matched against both commands and paths)
# TEMPLATE: Add your environment-specific hostnames below
# ─────────────────────────────────────────────────────────────────────────────

# Example patterns (uncomment and customize):
# your-db-host\.example\.com
# your-bucket-name
# 10\.0\.0\.\d+
